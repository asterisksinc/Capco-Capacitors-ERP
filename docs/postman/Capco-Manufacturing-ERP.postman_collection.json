{
  "info": {
    "name": "Capco Manufacturing ERP",
    "description": "Supabase Auth and PostgREST collection for Capco Manufacturing ERP backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "supabaseUrl", "value": "https://YOUR-PROJECT-REF.supabase.co" },
    { "key": "NEXT_PUBLIC_BACKEND_URL", "value": "http://localhost:3000" },
    { "key": "anonKey", "value": "your_supabase_anon_key" },
    { "key": "accessToken", "value": "" },
    { "key": "productionImageBucket", "value": "production-stage-images" },
    { "key": "productionImageObjectPath", "value": "raw-material/RM-9001/raw-material.jpg" },
    { "key": "rawMaterialImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/raw-material/RM-9001/raw-material.jpg" },
    { "key": "storeHeadReviewImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/raw-material/WO-2026-001/store-head-review.jpg" },
    { "key": "materialRequestQcImagePath", "value": "raw-material/MR-2001/material-request-qc.jpg" },
    { "key": "materialRequestQcImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/raw-material/MR-2001/material-request-qc.jpg" },
    { "key": "metallisationImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/metallisation/MC-2001/metallisation.jpg" },
    { "key": "metallisationReviewImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/metallisation/MC-2001/review.jpg" },
    { "key": "factoryWastageImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/metallisation/MC-2001/factory-wastage.jpg" },
    { "key": "weightPhotoUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/metallisation/MC-2001/weight.jpg" },
    { "key": "qcPhotoUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/metallisation/MC-2001/qc.jpg" },
    { "key": "slittingImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/slitting/SL-2001/slitting.jpg" },
    { "key": "slittingReviewImageUrl", "value": "https://YOUR-PROJECT-REF.supabase.co/storage/v1/object/public/production-stage-images/slitting/SL-2001/review.jpg" },
    { "key": "workOrderId", "value": "50000000-0000-0000-0000-000000000001" },
    { "key": "productOrderId", "value": "90000000-0000-0000-0000-000000000001" },
    { "key": "slittingId", "value": "70000000-0000-0000-0000-000000000003" },
    { "key": "slittingBatchId", "value": "" },
    { "key": "generatedDocumentId", "value": "" },
    { "key": "inventoryId", "value": "40000000-0000-0000-0000-000000000003" },
    { "key": "stockId", "value": "80000000-0000-0000-0000-000000000001" },
    { "key": "requestId", "value": "70000000-0000-0000-0000-000000000001" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Storage - Upload Production Stage Image",
      "request": {
        "method": "POST",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-upsert", "value": "true" },
          { "key": "Content-Type", "value": "image/jpeg" }
        ],
        "url": "{{supabaseUrl}}/storage/v1/object/{{productionImageBucket}}/{{productionImageObjectPath}}",
        "body": {
          "mode": "file",
          "file": {
            "src": ""
          }
        },
        "description": "Upload raw material, metallisation, or slitting images first. Use paths like raw-material/RM-9001/raw-material.jpg, metallisation/MC-2001/review.jpg, or slitting/SL-2001/review.jpg. Then store the public URL on the relevant API record."
      }
    },
    {
      "name": "Storage - Upload Material Request QC Image",
      "request": {
        "method": "POST",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-upsert", "value": "true" },
          { "key": "Content-Type", "value": "image/jpeg" }
        ],
        "url": "{{supabaseUrl}}/storage/v1/object/{{productionImageBucket}}/{{materialRequestQcImagePath}}",
        "body": {
          "mode": "file",
          "file": {
            "src": ""
          }
        },
        "description": "Upload the Store Head QC image for a raw-material issue request. Reuse the same production-stage-images bucket, but keep a separate path and URL for material request QC evidence."
      }
    },
    {
      "name": "Auth - Request OTP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{supabaseUrl}}/auth/v1/otp",
        "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919900000001\",\n  \"create_user\": false\n}" },
        "description": "Success response: { \"message_id\": \"...\" }\nError response: { \"message\": \"Invalid phone\" }"
      }
    },
    {
      "name": "Auth - Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{supabaseUrl}}/auth/v1/verify",
        "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+919900000001\",\n  \"token\": \"123456\",\n  \"type\": \"sms\"\n}" },
        "description": "Success response: { \"access_token\": \"...\", \"user\": {} }\nError response: { \"message\": \"Token has expired or is invalid\" }"
      }
    },
    {
      "name": "Auth - Password Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"superadmin@capco.local\",\n  \"password\": \"Capco@123\"\n}" },
        "description": "Success response: { \"access_token\": \"...\" }\nError response: { \"error_description\": \"Invalid login credentials\" }"
      }
    },
    {
      "name": "Dashboard - Work Order Counts",
      "request": {
        "method": "GET",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{supabaseUrl}}/rest/v1/work_orders?select=status",
        "description": "Success response: [{ \"status\": \"Completed\" }]\nError response: { \"message\": \"JWT expired\" }"
      }
    },
    {
      "name": "Inventory - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{supabaseUrl}}/rest/v1/inventory?select=*,qr_references(qr_payload,qr_url)&order=created_at.desc",
        "description": "Success response: [{ \"raw_material_code\": \"RM-8301\", \"status\": \"Being Used\" }]\nError response: { \"message\": \"permission denied\" }"
      }
    },
    {
      "name": "Inventory - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Prefer", "value": "return=representation" }
        ],
        "url": "{{supabaseUrl}}/rest/v1/inventory",
        "body": { "mode": "raw", "raw": "{\n  \"raw_material_code\": \"RM-9001\",\n  \"raw_material_name\": \"BOPP Capacitor Film\",\n  \"roll_no\": \"RL-2607-001\",\n  \"micron\": 4.5,\n  \"width_m\": 1.0,\n  \"net_weight_kg\": 58.5,\n  \"gross_weight_kg\": 60.0,\n  \"current_weight_kg\": 58.5,\n  \"supplier\": \"VedaCap Industries\",\n  \"temperature_c\": 25,\n  \"raw_material_image_url\": \"{{rawMaterialImageUrl}}\",\n  \"status\": \"In Inventory\",\n  \"stage\": \"Inventory\"\n}" },
        "description": "Success response: [{ \"id\": \"...\", \"raw_material_code\": \"RM-9001\" }]\nError response: { \"message\": \"duplicate key value violates unique constraint\" }"
      }
    },
    {
      "name": "Inventory - Update Raw Material Image",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "apikey", "value": "{{anonKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Prefer", "value": "return=representation" }
        ],
        "url": "{{supabaseUrl}}/rest/v1/inventory?id=eq.{{inventoryId}}",
        "body": { "mode": "raw", "raw": "{\n  \"raw_material_image_url\": \"{{rawMaterialImageUrl}}\"\n}" },
        "description": "Success response: [{ \"id\": \"...\", \"raw_material_image_url\": \"...\" }]\nError response: { \"message\": \"new row violates row-level security policy\" }"
      }
    },
    {
